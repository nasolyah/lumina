# Скопируй в .env и заполни. .env НЕ коммить в git.

# ОБЯЗАТЕЛЬНО: ключ Gemini из Google AI Studio (aistudio.google.com → Get API key).
GEMINI_API_KEY=вставь_сюда_ключ_gemini

# Необязательно — значения по умолчанию ниже.
# Модели Gemini: LIGHT — на извлечение (дёшево), POWER — на ответ (качество).
# Для максимума качества на питче можно поставить POWER_MODEL=gemini-2.5-pro.
LIGHT_MODEL=gemini-2.5-flash-lite
POWER_MODEL=gemini-2.5-flash

# Потолок выходных токенов ответа модели.
MAX_OUTPUT_TOKENS=1200

# "Мышление" Gemini 2.5 тратит выходные токены. Для JSON оно не нужно → 0 (дешевле).
# ВНИМАНИЕ: у gemini-2.5-pro минимум 128, полностью выключить нельзя.
THINKING_BUDGET=0

# Максимальная длина анализируемого текста в символах (защита от дорогих прогонов).
MAX_TEXT_CHARS=100000

# Число повторов вызова при транзиентной ошибке Gemini (429/5xx). Если модель
# штормит прямо перед демо — подними до 5.
LLM_RETRIES=3

CHUNK_SIZE=300
TOP_K=3
# На платном тарифе Gemini можно оставить 0.5; на бесплатном (низкий RPM) подними до 2-4.
CHUNK_DELAY=0.5

# Насколько бустить узел, чей тип совпал с намерением вопроса (type-aware ретрив).
# 0 = выключить буст и вернуться к чистому косинусу. 0.25 = +25%.
TYPE_BOOST=0.25

# Домены фронта через запятую (для CORS). * = разрешить всё (только для разработки).
# Прод-пример: ALLOWED_ORIGINS=https://lumina.uz,https://lum.pages.dev
ALLOWED_ORIGINS=*

# URL проекта Supabase (публичный) — по нему бэкенд берёт JWKS и проверяет
# токены пользователей. Тот же адрес, что в app.html. Без него /api/analyze
# и /api/extract вернут 500 (авторизация не настроена).
SUPABASE_URL=https://fyjofluosbonribyvssx.supabase.co
