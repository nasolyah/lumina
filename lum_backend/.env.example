# Скопируй в .env и заполни. .env НЕ коммить в git.

# ОБЯЗАТЕЛЬНО: новый ключ Groq (старый из зипа отзови!)
GROQ_API_KEY=gsk_вставь_сюда_новый_ключ

# Необязательно — значения по умолчанию ниже.
# Сверь актуальные строки моделей в console.groq.com/docs/models (каталог меняется).
LIGHT_MODEL=openai/gpt-oss-20b
POWER_MODEL=openai/gpt-oss-120b

# Fallback-модели через запятую: если основная недоступна, пробуются по порядку.
LIGHT_FALLBACKS=llama-3.1-8b-instant
POWER_FALLBACKS=qwen/qwen3.6-27b,llama-3.3-70b-versatile

CHUNK_SIZE=300
TOP_K=3
# На платном (developer) тарифе можно оставить 0.5; на free подними до 2.
CHUNK_DELAY=0.5

# Насколько бустить узел, чей тип совпал с намерением вопроса (type-aware ретрив).
# 0 = выключить буст и вернуться к чистому косинусу. 0.25 = +25%.
TYPE_BOOST=0.25

# Домены фронта через запятую (для CORS). * = разрешить всё (только для разработки).
# Прод-пример: ALLOWED_ORIGINS=https://lumina.uz,https://lum.pages.dev
ALLOWED_ORIGINS=*
